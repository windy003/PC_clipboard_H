<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 需要联网访问 Worker 接口 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/a2048x2048"
        android:label="D1剪贴板查看器"
        android:supportsRtl="true"
        android:theme="@style/Theme.ClipboardViewer">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 「记忆」条目数小部件 -->
        <receiver
            android:name=".MemoryWidgetProvider"
            android:label="d1剪贴板记忆"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.example.clipboardviewer.WIDGET_REFRESH" />
                <action android:name="com.example.clipboardviewer.WIDGET_REDRAW" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/memory_widget_info" />
        </receiver>
    </application>
</manifest>
