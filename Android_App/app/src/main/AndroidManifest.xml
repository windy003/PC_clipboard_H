<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 需要联网访问 Worker 接口 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- 写入「外部存储/1/local_3_days_later.txt」 -->
    <!-- Android 10 及以下用传统外部存储权限 -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!-- Android 11+ 写入外部存储根目录需「所有文件访问」权限 -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/a2048x2048"
        android:label="D1剪贴板查看器"
        android:requestLegacyExternalStorage="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.ClipboardViewer">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 垃圾箱界面 -->
        <activity
            android:name=".TrashActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity" />

        <!-- 本地「已发布」条目数小部件（后台同时负责云端转存与每日 8:00 检查） -->
        <receiver
            android:name=".LocalWidgetProvider"
            android:label="剪贴板本地"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.example.clipboardviewer.LOCAL_WIDGET_REFRESH" />
                <action android:name="com.example.clipboardviewer.LOCAL_WIDGET_REDRAW" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/local_widget_info" />
        </receiver>
    </application>
</manifest>
