# Cloudflare D1 收藏夹同步配置
# 把本文件复制为 .env 并填入你自己的值（.env 已被 .gitignore 忽略，不会提交）

# Cloudflare 账户 ID（Dashboard 右侧 Account ID，或 D1 数据库页面可见）
CLOUDFLARE_ACCOUNT_ID=your_account_id

# D1 数据库 ID（在 Cloudflare Dashboard > Storage & Databases > D1 中创建数据库后可见）
CLOUDFLARE_D1_DATABASE_ID=your_database_id

# API Token（创建一个具有 "D1 Edit" 权限的 Token）
# 路径：My Profile > API Tokens > Create Token > 自定义权限 Account > D1 > Edit
CLOUDFLARE_API_TOKEN=your_api_token
